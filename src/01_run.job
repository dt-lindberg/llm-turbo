#!/bin/bash

#SBATCH --job-name=Infrnc
#SBATCH --partition=gpu_a100
#SBATCH --time=01:00:00
#SBATCH --gpus=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=18
#SBATCH --output=slurm_output_%A.out

module purge
module load 2025
module load CUDA/12.8.0
module load Python/3.13.5-GCCcore-14.3.0

cd $HOME/Projects/llm-turbo/src

# Hardware monitor
HW_LOG="hw_monitor_${SLURM_JOB_ID}.csv"
bash monitor_hw.sh "$HW_LOG" 10 &
MONITOR_PID=$!

source .venv/bin/activate
python3 inference.py $SLURM_JOB_ID

# Stop monitor and print hardware report
kill "$MONITOR_PID" 2>/dev/null
wait "$MONITOR_PID" 2>/dev/null
python3 summarize_hw.py "$HW_LOG"

echo ""
python3 evaluate.py "$SLURM_JOB_ID"

echo ""
echo "Exiting job"
